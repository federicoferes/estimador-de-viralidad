# URL de tu HuggingFace Space (FastAPI endpoint)
# Ejemplo: https://tu-user-estimador-viralidad.hf.space
HF_SPACE_URL=

# Token de HuggingFace (si el Space es privado)
HF_TOKEN=

# API key de OpenRouter — para el generador de guiones virales con LLM
# Sacala en https://openrouter.ai/keys
OPENROUTER_API_KEY=
